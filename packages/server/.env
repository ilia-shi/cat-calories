DATABASE_PATH=./data.db
SERVER_PORT=8080
SERVER_SECRET=change-me-to-a-random-string

# OAuth provider (leave OAUTH_CLIENT_ID empty to disable)
OAUTH_ENDPOINT=http://casdoor:8000
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_ORGANIZATION=built-in
OAUTH_APPLICATION=cat-calories

# Server identity (used in /.well-known/sync-config)
SERVER_NAME=Cat Calories Sync
SERVER_VERSION=2.0.0
SERVER_BASE_URL=http://server.localhost:8080
