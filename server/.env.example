DATABASE_PATH=./data.db
SERVER_PORT=8080
SERVER_SECRET=change-me-to-a-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=http://localhost:8080/auth/facebook/callback

# Casdoor OAuth (leave CASDOOR_CLIENT_ID empty to disable)
CASDOOR_ENDPOINT=http://casdoor:8000
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ORGANIZATION=built-in
CASDOOR_APPLICATION=cat-calories

# Server identity (used in /.well-known/sync-config)
SERVER_NAME=Cat Calories Sync
SERVER_VERSION=2.0.0
SERVER_BASE_URL=http://localhost:8080
